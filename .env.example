# Copy to .env.local (gitignored) and point at ONE Supabase project at a time.
# Set BOTH URL and anon key in .env.local so they override .env together (avoid Paris URL + US key).
#
# Paris (EU): https://wlyncuwbzhzjafmqozcm.supabase.co — local EU testing / prod cutover.
# US (legacy): https://uwmlagvsivxqocklxbbo.supabase.co — legacy staging only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Netlify Edge (og-tags): set the same values in the Netlify UI as
# SUPABASE_URL / SUPABASE_ANON_KEY (or reuse VITE_* if exposed to Edge Functions).

# ── Upstash Redis (optional but strongly recommended for production) ──────────
# Create a free Redis database at https://upstash.com (no card required).
# Copy the REST URL and REST token from the Upstash console → your database → REST API.
#
# These are FRONTEND env vars (used by EventContext to call the Edge Function).
# The Edge Function reads UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
# from Supabase Secrets (Settings → Edge Functions → Secrets in Supabase dashboard).
#
# If left empty: app falls back to direct Supabase queries — no feature is broken.
VITE_UPSTASH_ENABLED=true

# Also add these to Supabase Edge Function Secrets (NOT prefixed with VITE_):
#   UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
#   UPSTASH_REDIS_REST_TOKEN=AXxx...
#   CACHE_INVALIDATION_SECRET=your-random-secret  (optional extra auth for invalidation)
